# Expo environment variables
# This is an example file. Create a .env file and set your actual values.

# Your computer's local IP address (find with: ifconfig | grep "inet ")
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000

# Supabase public API values (from Project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
